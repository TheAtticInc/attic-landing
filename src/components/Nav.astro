---
// Nav — shared across every page. Sticky, blurred on scroll.
// Links are anchor-based on the landing page; on sub-pages they deep-link
// back to the landing's sections.
interface Props {
  /** Where internal anchor links resolve from. Default: landing-relative. */
  homeBase?: string;
}
const { homeBase = '/' } = Astro.props;
---

<nav class="nav">
  <div class="wrap nav__inner">
    <a href="/" class="brand" aria-label="Attic home">
      <svg class="brand__mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <image href="/logo-mark.png" x="0" y="0" width="32" height="32" />
      </svg>
      Attic
    </a>
    <div class="nav__links">
      <a href={`${homeBase}#pricing`}>Pricing</a>
      <a href={`${homeBase}#life`}>Why Attic</a>
      <a href={`${homeBase}#faq`}>FAQ</a>
    </div>
  </div>
</nav>
