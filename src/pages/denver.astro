---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';
import '../styles/denver.css';
---

<BaseLayout
  title="Denver — Attic"
  description="Attic is Denver's on-demand personal storage service. Climate-controlled storage and next-day delivery across Highland, RiNo, Cap Hill, Wash Park, Cherry Creek, and beyond."
  ogTitle="Attic — Storage at Denver pace"
  ogDescription="Colorado built. Built for next-day returns across the metro."
>

<header class="dv-hero">
  <div class="wrap">
    <div class="dv-hero__grid">
      <div>
        <p class="eyebrow">Denver &amp; the Front Range</p>
        <h1>Storage,<br/><em>at Denver pace.</em></h1>
        <p class="lede">Colorado built. Colorado based. Climate-controlled storage with next-day returns to any doorstep in the metro.</p>
        <div class="hero__cta">
          <a class="btn btn-primary btn-lg" href="/#waitlist">Request an invite</a>
          <a class="btn btn-ghost btn-lg" href="#neighborhoods">Check your neighborhood →</a>
        </div>
      </div>
      <div aria-hidden="true">
        <svg viewBox="0 0 500 440" style="width:100%;height:auto;border-radius:22px;box-shadow:var(--sh-2);">
          <defs>
            <radialGradient id="mg" cx="50%" cy="50%"><stop offset="0%" stop-color="#F9DFC8"/><stop offset="100%" stop-color="#F5EADB"/></radialGradient>
          </defs>
          <rect width="500" height="440" fill="url(#mg)" rx="22"/>
          <g fill="#8C7A68" opacity="0.25"><path d="M 0 80 L 60 40 L 120 70 L 180 30 L 240 60 L 300 20 L 360 50 L 420 35 L 500 70 L 500 100 L 0 100 Z"/></g>
          <g stroke="#D4C3A4" stroke-width="2" fill="none" opacity="0.8">
            <path d="M 0 220 L 500 200"/><path d="M 0 300 L 500 290"/><path d="M 0 380 L 500 370"/>
            <path d="M 140 100 L 160 440"/><path d="M 260 100 L 280 440"/><path d="M 380 100 L 400 440"/>
          </g>
          <path d="M 150 100 Q 200 220 180 440" stroke="#C65D3C" stroke-width="3" fill="none" stroke-dasharray="6 4" opacity="0.6"/>
          <g font-family="'Inter',sans-serif" font-size="11" font-weight="500" fill="#5A4A3C">
            <g><circle cx="180" cy="240" r="6" fill="#C65D3C"/><text x="195" y="244">Highland</text></g>
            <g><circle cx="260" cy="220" r="6" fill="#C65D3C"/><text x="275" y="224">RiNo</text></g>
            <g><circle cx="270" cy="280" r="6" fill="#C65D3C"/><text x="285" y="284">Cap Hill</text></g>
            <g><circle cx="240" cy="340" r="6" fill="#C65D3C"/><text x="255" y="344">Wash Park</text></g>
            <g><circle cx="360" cy="300" r="6" fill="#C65D3C"/><text x="375" y="304">Cherry Creek</text></g>
            <g><circle cx="160" cy="180" r="6" fill="#C65D3C"/><text x="175" y="184">Berkeley</text></g>
            <g><circle cx="130" cy="320" r="6" fill="#C65D3C"/><text x="145" y="324">Sunnyside</text></g>
            <g><circle cx="330" cy="360" r="6" fill="#C65D3C"/><text x="345" y="364">Platt Park</text></g>
          </g>
        </svg>
      </div>
    </div>
  </div>
</header>

<section class="stripe stripe--paper">
  <div class="wrap">
    <div style="max-width:680px;margin-bottom:40px;">
      <p class="eyebrow">What you get</p>
      <h2 class="h2">Denver, <em>by the crate.</em></h2>
    </div>
    <div class="dv-stats">
      <div class="dv-stats__cell"><div class="dv-stats__num">Denver</div><div class="dv-stats__label">Built and based in Colorado</div></div>
      <div class="dv-stats__cell"><div class="dv-stats__num">Climate</div><div class="dv-stats__label">Held at 65–72°F year-round</div></div>
      <div class="dv-stats__cell"><div class="dv-stats__num">Insured</div><div class="dv-stats__label">Up to $2,000 per crate</div></div>
      <div class="dv-stats__cell"><div class="dv-stats__num">Tracked</div><div class="dv-stats__label">QR-scanned end-to-end</div></div>
    </div>
  </div>
</section>

<section id="neighborhoods" class="stripe">
  <div class="wrap">
    <div style="max-width:680px;margin-bottom:40px;">
      <p class="eyebrow">Neighborhoods</p>
      <h2 class="h2">Where we're<br/><em>rolling out.</em></h2>
      <p class="body-lg" style="margin-top:16px;">Targeting next-day windows across these neighborhoods as we open up invites.</p>
    </div>
    <div class="dv-nbh">
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Highland</p><p class="dv-nbh__stat">80211 · 80212</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">RiNo</p><p class="dv-nbh__stat">80205</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Capitol Hill</p><p class="dv-nbh__stat">80203 · 80218</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Washington Park</p><p class="dv-nbh__stat">80210 · 80209</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Cherry Creek</p><p class="dv-nbh__stat">80206</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Berkeley</p><p class="dv-nbh__stat">80212 · 80221</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Sunnyside</p><p class="dv-nbh__stat">80211</p><p class="dv-nbh__eta">Rolling out</p></div>
      <div class="dv-nbh__tile"><p class="dv-nbh__name">Platt Park</p><p class="dv-nbh__stat">80210</p><p class="dv-nbh__eta">Rolling out</p></div>
    </div>
    <p class="body" style="margin-top:32px;">Coming after Denver: Aurora, Lakewood, Englewood, and Boulder. <a href="mailto:hi@attic.it.com?subject=Denver%20expansion">Ping us</a> to jump the line in your area.</p>
  </div>
</section>

<section class="cta-final">
  <div class="wrap-narrow">
    <h2>Ready to get some <em>space back?</em></h2>
    <p class="sub">If you're in Denver, you can be tucking crates in next week.</p>
    <form class="email-form" data-email-form novalidate>
      <div data-email-fields>
        <div class="email-form__row">
          <input
            type="email"
            name="email"
            placeholder="you@email.com"
            required
            autocomplete="email"
            inputmode="email"
            aria-label="Email address"
            class="email-form__input"
          />
        </div>
        <div class="email-form__row email-form__row--action">
          <input
            type="text"
            name="zip"
            placeholder="80210"
            required
            autocomplete="postal-code"
            inputmode="numeric"
            pattern="\d{5}"
            maxlength="5"
            aria-label="ZIP code"
            class="email-form__input email-form__zip"
          />
          <button type="submit" class="email-form__submit">Request invite</button>
        </div>
      </div>
      <input type="text" name="_h" tabindex="-1" autocomplete="off" aria-hidden="true" class="email-form__honeypot" />
      <div class="email-form__error" data-email-error role="alert"></div>
      <div class="email-form__success" data-email-success role="status">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>You're on the list. Check your inbox to confirm — we sent a quick note to make sure it's really you.</span>
      </div>
      <p class="email-form__fine">We'll email you when your invite's ready, and occasionally with launch updates. Unsubscribe anytime.</p>
    </form>
  </div>
</section>

</BaseLayout>
