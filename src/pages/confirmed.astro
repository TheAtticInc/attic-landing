---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're on the list — Attic"
  description="Your spot on the Attic waitlist is confirmed. We'll be in touch as Denver opens up."
  ogTitle="You're on the list — Attic"
  ogDescription="Confirmed. We'll be in touch as Denver opens up."
>

<section class="cta-final" style="min-height:70vh;display:flex;align-items:center;">
  <div class="wrap-narrow" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:50%;background:#5F8351;color:#FFF8EE;margin-bottom:24px;">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h2 style="margin-bottom:18px;">You're <em>in</em>.</h2>
    <p class="sub" style="margin-bottom:14px;">Your spot's confirmed. Denver opens in small batches — we'll send your invite as soon as your area's covered.</p>
    <p class="email-form__fine" style="max-width:480px;margin:0 auto 28px;">Watch for a welcome email from <strong>hi@attic.it.com</strong> in the next few minutes. If a friend in your neighborhood signs up too, you'll both jump the line — fuller blocks get scheduled first.</p>
    <a class="btn btn-ghost btn-lg" href="/">Back to the site →</a>
  </div>
</section>

</BaseLayout>
