---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';
---

<BaseLayout
  title="Attic — Personal storage, on demand in Denver"
  description="Attic picks up your crates, stores them safely in climate-controlled Denver storage, and delivers them back when you need them. $15 per crate per month, flat."
  ogTitle="Attic — Personal storage, on demand"
  ogDescription="Your things, out of the way and on demand. $15/crate/month."
>


<!-- ===================================================================
     HERO
     =================================================================== -->
<header class="hero">
  <div class="hero-dust" data-dust aria-hidden="true"></div>
  <div class="wrap">
    <div class="hero__grid">
      <!-- LEFT: copy -->
      <div>
        <span class="hero__label">
          <span class="hero__label-dot"></span>
          Opening Denver — neighborhood by neighborhood
        </span>
        <h1 class="hero__h1">Your things,<br/><em>tucked away.</em></h1>
        <p class="hero__lede">Storage that comes to you — not the other way around.</p>
        <p class="hero__sub">
          We drop off sturdy crates, pick them up when you're packed,
          and tuck them away in climate-controlled Denver storage.
          Call anything back in a tap. $15 a crate, a month.
        </p>
        <div class="hero__cta">
          <a class="btn btn-primary btn-lg" href="#waitlist">Request an invite</a>
          <a class="btn btn-ghost btn-lg" href="#how">See how it works →</a>
        </div>
        <div class="hero__ticker" data-ticker aria-live="polite">
          <span class="hero__ticker-dot"></span>
          <div class="hero__ticker-lines">
            <span data-ticker-line>Climate-controlled Denver storage</span>
            <span data-ticker-line>Insured up to <strong>$2,000</strong> per crate</span>
            <span data-ticker-line>Scanned at <strong>every handoff</strong></span>
            <span data-ticker-line>No contract. Cancel any crate any time.</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: hero anchor figure. Placeholder for the post-Maddie
           lifestyle shoot. Until /images/hero.jpg exists, this renders as a
           brand-color composition with the attic-window motif; the <img>
           picks up automatically when the photo is dropped in.
           See public/images/README.md for the photo brief. -->
      <div class="hero__stage" aria-hidden="true">
        <figure class="hero__figure">
          <img src="/images/hero.jpg" alt="" class="hero__img" loading="eager" decoding="async" onerror="this.style.display='none'"/>
          <span class="hero__figure-mark" aria-hidden="true">
            <svg viewBox="0 0 80 80" width="72" height="72">
              <circle cx="40" cy="40" r="32" fill="none" stroke="currentColor" stroke-width="2"/>
              <line x1="8" y1="40" x2="72" y2="40" stroke="currentColor" stroke-width="1.5"/>
              <line x1="40" y1="8" x2="40" y2="72" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
        </figure>
      </div>
      <!-- LEGACY-REMOVED: cartoon attic-house SVG + cycling phone-card stack
           removed 2026-05-14. See git history pre-c5af80e for the original
           markup. Kept the brand-aligned attic-window motif above as the
           one quiet visual gesture. -->

    </div>
  </div>
</header>

<!-- ===================================================================
     PROOF STRIP
     =================================================================== -->
<section class="proof">
  <div class="wrap">
    <div class="proof__grid">
      <div class="proof__item">
        <div class="proof__num">Climate</div>
        <div class="proof__label">Held at 65–72°F year-round</div>
      </div>
      <div class="proof__item">
        <div class="proof__num">Insured</div>
        <div class="proof__label">Up to $2,000 per crate</div>
      </div>
      <div class="proof__item">
        <div class="proof__num">Tracked</div>
        <div class="proof__label">QR-scanned at every handoff</div>
      </div>
      <div class="proof__item">
        <div class="proof__num">Denver</div>
        <div class="proof__label">Built and based in Colorado</div>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     DAY WITH ATTIC
     =================================================================== -->
<section id="how" class="stripe stripe--paper day">
  <div class="wrap">
    <div class="day__head reveal">
      <div class="day__head-left">
        <p class="eyebrow">A day with Attic</p>
        <h2 class="h2">Four taps. One truck.<br/><em>Zero storage-unit weekends.</em></h2>
      </div>
      <p class="body-lg" style="max-width:360px;">From "I need crates" to "it's back in my closet" — the whole loop, on a single timeline.</p>
    </div>

    <div class="day__track">
      <div class="day__rail" aria-hidden="true"></div>

      <div class="day__step reveal" data-delay="1">
        <div class="day__pin" data-tone="t">1</div>
        <p class="day__time">Tuesday · evening</p>
        <h3>Order, we drop off</h3>
        <p>Pick how many you need. Sturdy, stackable crates land at your door tomorrow — first delivery's on us.</p>
      </div>
      <div class="day__step reveal" data-delay="2">
        <div class="day__pin" data-tone="m">2</div>
        <p class="day__time">Saturday · whenever</p>
        <h3>You pack them</h3>
        <p>Fill them at your pace. Label and snap a photo of what's inside from the app, so future-you can find it.</p>
      </div>
      <div class="day__step reveal" data-delay="3">
        <div class="day__pin" data-tone="m">3</div>
        <p class="day__time">Monday · afternoon</p>
        <h3>We pick them up</h3>
        <p>A driver scans each one and loads them up. You get a "tucked in" note when they land on the shelf.</p>
      </div>
      <div class="day__step reveal" data-delay="4">
        <div class="day__pin" data-tone="moss">4</div>
        <p class="day__time">Months later · next day</p>
        <h3>Call anything back</h3>
        <p>Tap "send it back." It's on your porch tomorrow — same flat rate, no fetch fee.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     FACILITY
     =================================================================== -->
<section class="stripe stripe--dark facility">
  <div class="wrap">
    <div class="facility__grid">
      <div class="reveal">
        <p class="eyebrow">Inside the attic</p>
        <h2 class="h2" style="color:#F5EADB;">A proper home for<br/>your things.</h2>
        <p class="body-lg" style="margin-top:24px;max-width:460px;">Our Denver storage isn't a garage unit. It's climate-controlled, scan-tracked, and insured — purpose-built for the stuff you want to keep but don't need underfoot.</p>

        <div class="facility__features">
          <div class="fac-feat reveal" data-delay="1">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div>
              <h4>Secured 24/7</h4>
              <p>Keycard access, cameras, motion sensors. Only named staff ever touch a crate.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="2">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
            </div>
            <div>
              <h4>Climate-controlled</h4>
              <p>Held at 65–72°F year-round. No freeze, no bake, no musty-garage funk.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="3">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3h-3zM18 14h3M14 18h3M18 21h3"/></svg>
            </div>
            <div>
              <h4>Every crate scanned</h4>
              <p>QR-coded and scanned at pickup, intake, shelf placement, and return. Full custody trail.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="4">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h4>Insured to $2,000</h4>
              <p>Every crate, every month, baked into the price. No extra rider to buy.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="facility__scene reveal" data-delay="2" aria-hidden="true">
        <!-- Warehouse interior cross-section: shelving with bins + glow -->
        <svg viewBox="0 0 600 450" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="shelfGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3A2A1A"/>
              <stop offset="100%" stop-color="#1A120A"/>
            </linearGradient>
            <radialGradient id="warmLight" cx="50%" cy="30%">
              <stop offset="0%" stop-color="#FBEECB" stop-opacity="0.4"/>
              <stop offset="60%" stop-color="#E8B84A" stop-opacity="0.1"/>
              <stop offset="100%" stop-color="#140D07" stop-opacity="0"/>
            </radialGradient>
          </defs>

          <!-- background glow -->
          <rect width="600" height="450" fill="#140D07"/>
          <ellipse cx="300" cy="130" rx="300" ry="200" fill="url(#warmLight)"/>

          <!-- floor -->
          <path d="M 0 380 L 600 380 L 600 450 L 0 450 Z" fill="#0A0704"/>
          <!-- perspective floor lines -->
          <g stroke="#3A2A1A" stroke-width="1" opacity="0.5">
            <line x1="0" y1="400" x2="600" y2="400"/>
            <line x1="0" y1="420" x2="600" y2="420"/>
          </g>

          <!-- warehouse shelving (3 rows, deep perspective) -->
          <!-- back row, smallest -->
          <g transform="translate(140 100)">
            <rect x="0" y="0" width="320" height="240" fill="url(#shelfGrad)" stroke="#4A3820" stroke-width="1"/>
            <!-- horizontal shelf lines -->
            <line x1="0" y1="60" x2="320" y2="60" stroke="#5A4028" stroke-width="2"/>
            <line x1="0" y1="120" x2="320" y2="120" stroke="#5A4028" stroke-width="2"/>
            <line x1="0" y1="180" x2="320" y2="180" stroke="#5A4028" stroke-width="2"/>
            <!-- vertical supports -->
            <line x1="80" y1="0" x2="80" y2="240" stroke="#4A3820" stroke-width="1.5"/>
            <line x1="160" y1="0" x2="160" y2="240" stroke="#4A3820" stroke-width="1.5"/>
            <line x1="240" y1="0" x2="240" y2="240" stroke="#4A3820" stroke-width="1.5"/>

            <!-- bins: row 1 -->
            <g transform="translate(8 14)">
              <rect width="60" height="42" rx="3" fill="#C65D3C"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>
            <g transform="translate(88 14)">
              <rect width="60" height="42" rx="3" fill="#6B8E5A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>
            <g transform="translate(168 14)">
              <rect width="60" height="42" rx="3" fill="#E8B84A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#23180F" opacity="0.3"/>
            </g>
            <g transform="translate(248 14)">
              <rect width="60" height="42" rx="3" fill="#5A7FA3"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>

            <!-- row 2 -->
            <g transform="translate(8 74)"><rect width="60" height="42" rx="3" fill="#A6436A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(88 74)"><rect width="60" height="42" rx="3" fill="#C65D3C"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(168 74)"><rect width="60" height="42" rx="3" fill="#6B8E5A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(248 74)"><rect width="60" height="42" rx="3" fill="#E8B84A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#23180F" opacity="0.3"/></g>

            <!-- row 3 -->
            <g transform="translate(8 134)"><rect width="60" height="42" rx="3" fill="#5A7FA3"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(88 134)"><rect width="60" height="42" rx="3" fill="#C65D3C"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(168 134)"><rect width="60" height="42" rx="3" fill="#A6436A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(248 134)"><rect width="60" height="42" rx="3" fill="#6B8E5A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>

            <!-- row 4 -->
            <g transform="translate(8 194)"><rect width="60" height="42" rx="3" fill="#E8B84A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#23180F" opacity="0.3"/></g>
            <g transform="translate(88 194)"><rect width="60" height="42" rx="3" fill="#5A7FA3"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(168 194)"><rect width="60" height="42" rx="3" fill="#C65D3C"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
            <g transform="translate(248 194)"><rect width="60" height="42" rx="3" fill="#A6436A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/></g>
          </g>

          <!-- hanging pendant light -->
          <line x1="300" y1="0" x2="300" y2="70" stroke="#4A3820" stroke-width="1"/>
          <circle cx="300" cy="78" r="12" fill="#FBEECB" opacity="0.9"/>
          <circle cx="300" cy="78" r="24" fill="#FBEECB" opacity="0.2"/>

          <!-- shelf label at bottom -->
          <rect x="260" y="344" width="80" height="20" rx="3" fill="#2A1D10" stroke="#4A3820"/>
          <text x="300" y="358" fill="#E8B84A" font-family="monospace" font-size="11" text-anchor="middle" letter-spacing="1">SHELF B-12</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     CRATE ITSELF — the product
     =================================================================== -->
<section class="stripe bin">
  <div class="wrap">
    <div class="bin__grid">
      <div class="bin__art reveal" aria-hidden="true">
        <!-- Crate product photo slot. When public/images/crate.jpg lands
             the figure picks it up; until then renders the brand placeholder. -->
        <figure class="bin__figure">
          <img src="/images/crate.jpg" alt="" class="bin__img" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
        </figure>
      </div>

      <div class="reveal" data-delay="1">
        <p class="eyebrow">The crate</p>
        <h2 class="h2">One container,<br/>considered.</h2>
        <p class="body-lg" style="margin-top:20px;">Heavy-grade polyethylene, made in the USA. Open-top with carry handles, zip-tie sealable for security. Stackable, nestable when empty. A QR plate that never falls off. Nothing fancy — just the right crate.</p>

        <dl class="bin__specs">
          <div class="bin__spec">
            <dt>Capacity</dt>
            <dd>19<small>gal</small></dd>
          </div>
          <div class="bin__spec">
            <dt>Dimensions</dt>
            <dd>27×17×12<small>in</small></dd>
          </div>
          <div class="bin__spec">
            <dt>Pack limit</dt>
            <dd>50<small>lbs</small></dd>
          </div>
          <div class="bin__spec">
            <dt>Stack height</dt>
            <dd>5<small>crates</small></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

<!-- APP PREVIEW section removed 2026-05-14 — the 4-phone mockup gallery
     fought the negative-space brand direction and did not match the
     actual app UI. See git history pre-c5af80e for the original markup. -->

<!-- ===================================================================
     COMPARE — at-home vs self-storage vs Attic
     The honest three-way framing before the price reveal. Sets the
     value of Attic in the customer's own comparison: keeping things at
     home (free but costs square footage), a self-storage unit ($100+
     and a commute), or Attic ($15/crate and we bring the truck).
     =================================================================== -->
<section id="compare" class="stripe stripe--paper compare">
  <div class="wrap">
    <div class="compare__head reveal">
      <p class="eyebrow">How it stacks up</p>
      <h2 class="h2">Three ways to handle<br/><em>the things you keep around.</em></h2>
      <p class="lede" style="margin-top:20px;">Keeping stuff at home costs you square footage. A storage unit costs you weekends. Attic costs $15 a crate — and brings the truck.</p>
    </div>

    <div class="compare__grid">

      <!-- At home -->
      <article class="compare__card reveal" data-delay="1">
        <p class="compare__card-tag">Keep it at home</p>
        <h3>The default</h3>
        <p class="compare__card-price">$0<span class="per">/ month</span></p>
        <ul class="compare__card-list">
          <li>Lives in your closets, your garage, the spare room you wanted as an office.</li>
          <li>You haul it, you organize it, you dig when you need something.</li>
          <li>Takes up square footage you're already paying for.</li>
          <li>Climate depends on your basement.</li>
        </ul>
        <p class="compare__card-closer">Cheapest on paper.<br/>Costs you space every day.</p>
      </article>

      <!-- Self-storage unit -->
      <article class="compare__card reveal" data-delay="2">
        <p class="compare__card-tag">Rent a storage unit</p>
        <h3>The traditional fix</h3>
        <p class="compare__card-price">$100+<span class="per">/ month</span></p>
        <ul class="compare__card-list">
          <li>Lives across town behind a chain-link fence.</li>
          <li>You drive, you load, you unload — every visit.</li>
          <li>Minimum unit size is bigger than what you actually need.</li>
          <li>Access depends on gate hours.</li>
        </ul>
        <p class="compare__card-closer">Solves the space problem.<br/>Adds a commute.</p>
      </article>

      <!-- Attic -->
      <article class="compare__card compare__card--featured reveal" data-delay="3">
        <p class="compare__card-tag">The Attic way</p>
        <h3>Best of both</h3>
        <p class="compare__card-price">$15<span class="per">/ crate / month</span></p>
        <ul class="compare__card-list">
          <li>Lives in our climate-controlled Denver facility.</li>
          <li>We pick up. We deliver. You decide what and when.</li>
          <li>Pay for the crates you use — not a unit you don't fill.</li>
          <li>Insured up to $2,000 per crate.</li>
        </ul>
        <p class="compare__card-closer">All the benefits of a unit.<br/>None of the haul.</p>
      </article>

    </div>
  </div>
</section>

<!-- ===================================================================
     PRICING
     =================================================================== -->
<section id="pricing" class="stripe pricing">
  <div class="wrap">
    <div class="reveal" style="text-align:center;max-width:640px;margin:0 auto 56px;">
      <p class="eyebrow">What it costs</p>
      <h2 class="h2">One price. <em>No surprises.</em></h2>
      <p class="lede" style="margin-top:20px;">Flat rate, everything bundled. Cancel any crate anytime — we pick it up for free.</p>
    </div>

    <div class="pricing__card reveal" data-delay="1">
      <div class="pricing__head">
        <div>
          <p class="pricing__label">Flat rate · Colorado</p>
          <h3 class="pricing__title">Per crate, per month.<br/>That's the whole price.</h3>
        </div>
        <div class="pricing__num">
          <span class="pricing__num-dollar">$</span>
          <span>15</span>
          <span class="pricing__num-per">/ crate / mo</span>
        </div>
      </div>

      <div class="pricing__grid">
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Free first delivery</h4>
            <p>We bring empty crates to your door on order one.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>One trip a month</h4>
            <p>Pickup or delivery included at no extra cost.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Climate-controlled</h4>
            <p>Held at 65–72°F. No heat, freeze, or damp.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Chain-of-custody</h4>
            <p>Scanned at every handoff, pickup to shelf.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Insured to $2,000</h4>
            <p>Every crate. No extra rider. No deductible.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Send back free</h4>
            <p>Done with a crate? We fetch it, no fee.</p>
          </div>
        </div>
      </div>

      <div class="pricing__foot">
        <p>No contract. No minimum crate count. No per-mile fees.</p>
        <a class="btn btn-dark" href="#waitlist">Request an invite →</a>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     WHAT FITS / WHAT DOESN'T
     =================================================================== -->
<section class="stripe stripe--paper fits">
  <div class="wrap">
    <div class="reveal" style="margin-bottom:48px;max-width:760px;">
      <p class="eyebrow">What goes in</p>
