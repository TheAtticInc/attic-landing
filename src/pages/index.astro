---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';
---

<BaseLayout
  title="Attic: Personal storage, on demand in Denver"
  description="Attic picks up your crates, seals and stores them safely in our Denver facility, and brings them back with a tap in the app. $15 per crate per month, flat."
  ogTitle="Attic: Personal storage, on demand"
  ogDescription="Your things, out of the way and on demand. $15/crate/month."
>


<!-- ===================================================================
     HERO: value prop on the left, the actual app on the right.
     App-first direction (2026-07-09): the fastest way to explain Attic
     is to show the product. Two framed screenshots + store badges.
     =================================================================== -->
<header class="hero">
  <div class="hero-dust" data-dust aria-hidden="true"></div>
  <div class="wrap">
    <div class="hero__grid">
      <!-- LEFT: copy + CTAs -->
      <div>
        <span class="hero__label">
          <span class="hero__label-dot"></span>
          Opening Denver, neighborhood by neighborhood
        </span>
        <h1 class="hero__h1">More room<br/><em>for your life.</em></h1>
        <p class="hero__lede">Attic is valet storage, by the crate. We do the heavy lifting; you get your space back.</p>
        <p class="hero__sub">
          The holiday decor, off-season coats, and the craft stash crowding your
          closet — out of the way, back whenever you want. Flat $15 a crate, a month,
          all managed from an app that feels like home.
        </p>

        <div class="hero__cta">
          <a class="btn btn-primary btn-lg" href="#waitlist">Request an invite</a>
          <a class="btn btn-ghost btn-lg" href="#how">See how it works →</a>
        </div>

        <!-- Store badges: apps aren't public yet, so these funnel to the
             waitlist. Swap each href for the real listing URL at launch. -->
        <div class="hero__stores">
          <div class="store-badges">
            <a href="#waitlist" aria-label="App Store — coming soon. Join the waitlist for first access.">
              <img src="/images/appstore-badge.svg" alt="Download on the App Store" width="144" height="48" loading="lazy" decoding="async" />
            </a>
            <a href="#waitlist" aria-label="Google Play — coming soon. Join the waitlist for first access.">
              <img src="/images/googleplay-badge.png" alt="Get it on Google Play" width="124" height="48" loading="lazy" decoding="async" />
            </a>
          </div>
          <p class="store-note">Launching with Denver · Join the waitlist for first access</p>
        </div>

        <div class="hero__ticker" data-ticker aria-live="polite">
          <span class="hero__ticker-dot"></span>
          <div class="hero__ticker-lines">
            <span data-ticker-line>Picked up and delivered to your door</span>
            <span data-ticker-line>Sealed at your door with <strong>tamper-evident ties</strong></span>
            <span data-ticker-line>Every crate <strong>insured</strong></span>
            <span data-ticker-line>Scanned at <strong>every handoff</strong></span>
            <span data-ticker-line>No contract. Cancel any crate any time.</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: the app itself. Home screen front, crate detail behind. -->
      <div class="hero__stage">
        <div class="hero__phones">
          <div class="phone-frame hero__phone hero__phone--back">
            <img src="/images/app/app-crate.png" alt="Attic app crate detail screen: a Camping Gear crate with photo, category, and a journey tracker from home to storage" width="720" height="1600" loading="eager" decoding="async" />
          </div>
          <div class="phone-frame hero__phone hero__phone--front">
            <img src="/images/app/app-home.png" alt="Attic app home screen: your crates at a glance, each with a photo and live status like 'heading to storage' or 'at home with you'" width="720" height="1600" loading="eager" decoding="async" />
          </div>
        </div>
      </div>

    </div>
  </div>
</header>

<main>

<!-- ===================================================================
     HOW IT WORKS: the full mechanic in four numbered beats.
     =================================================================== -->
<section id="how" class="stripe stripe--paper how">
  <div class="wrap">
    <div class="how__head reveal">
      <p class="eyebrow">How it works</p>
      <h2 class="h2">Storage that comes<br/><em>to your door.</em></h2>
      <p class="lede" style="margin-top:20px;">No storage unit across town. No van rental. Four steps, and none of them involve you lifting more than a phone.</p>
    </div>

    <ol class="how__steps">
      <li class="how__step reveal" data-delay="1">
        <span class="how__num" aria-hidden="true">1</span>
        <h3>Order crates</h3>
        <p>Pick how many you need in the app. Empty crates arrive at your door — delivery's free.</p>
      </li>
      <li class="how__step reveal" data-delay="2">
        <span class="how__num" aria-hidden="true">2</span>
        <h3>Pack at your pace</h3>
        <p>Fill them with whatever's crowding your space. No boxes to buy, no tape, nothing to haul.</p>
      </li>
      <li class="how__step reveal" data-delay="3">
        <span class="how__num" aria-hidden="true">3</span>
        <h3>We seal, scan &amp; store</h3>
        <p>Your driver seals each crate at your door and scans it at every handoff on the way to our Denver facility.</p>
      </li>
      <li class="how__step reveal" data-delay="4">
        <span class="how__num" aria-hidden="true">4</span>
        <h3>Back in a tap</h3>
        <p>Need something? Tap "send it back" in the app and it's on your porch, usually next day.</p>
      </li>
    </ol>
  </div>
</section>

<!-- ===================================================================
     SECURITY: chain of custody. The differentiator, given its own band.
     Evening-sky navy (same family as the pricing card) so it reads as
     a serious, load-bearing moment between the lighter sections.
     =================================================================== -->
<section id="security" class="security">
  <div class="wrap">
    <div class="security__head reveal">
      <p class="eyebrow">Chain of custody</p>
      <h2 class="h2">Sealed at your door.<br/><em>Opened only by you.</em></h2>
      <p class="security__lede">
        Every crate is closed in front of you with a one-time, QR-coded security seal —
        and it stays sealed until it's back in your hands.
      </p>
    </div>

    <!-- the custody trail, beat by beat -->
    <div class="security__trail reveal" data-delay="1" role="list" aria-label="Every point where your crate is scanned">
      <span class="security__trail-step" role="listitem">Your door</span>
      <span class="security__trail-arrow" aria-hidden="true">→</span>
      <span class="security__trail-step" role="listitem">The van</span>
      <span class="security__trail-arrow" aria-hidden="true">→</span>
      <span class="security__trail-step" role="listitem">The facility</span>
      <span class="security__trail-arrow" aria-hidden="true">→</span>
      <span class="security__trail-step" role="listitem">The shelf</span>
      <span class="security__trail-arrow" aria-hidden="true">→</span>
      <span class="security__trail-step" role="listitem">Back to you</span>
    </div>
    <p class="security__trail-note reveal" data-delay="1">Scanned and logged at every single one.</p>

    <div class="security__grid">
      <article class="security__card reveal" data-delay="1">
        <div class="security__card-icon">
          <svg viewBox="0 0 48 48" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="10" y="10" width="12" height="12" rx="1.5"/><path d="M14 14 h4 v4 h-4 z"/><rect x="26" y="10" width="12" height="12" rx="1.5"/><path d="M30 14 h4 v4 h-4 z"/><rect x="10" y="26" width="12" height="12" rx="1.5"/><path d="M14 30 h4 v4 h-4 z"/><path d="M26 26 h5 v5"/><path d="M38 26 v5"/><path d="M26 38 h5 v-4"/><path d="M35 33 h3 v5 h-4"/></svg>
        </div>
        <h3>Tamper-evident seals</h3>
        <p>A uniquely numbered QR seal locks each crate shut at pickup. It can't be opened and resealed — if anything were off, you'd see it instantly.</p>
      </article>

      <article class="security__card reveal" data-delay="2">
        <div class="security__card-icon">
          <svg viewBox="0 0 48 48" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="24" cy="24" r="17"/><path d="M24 13 v11 l7 5"/></svg>
        </div>
        <h3>Scanned at every handoff</h3>
        <p>Every scan is logged with who, where, and when — a complete custody trail for every crate, from your door and back.</p>
      </article>

      <article class="security__card reveal" data-delay="3">
        <div class="security__card-icon">
          <svg viewBox="0 0 48 48" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 24 C10 15 16.5 10 24 10 C31.5 10 38 15 42 24 C38 33 31.5 38 24 38 C16.5 38 10 33 6 24 Z"/><circle cx="24" cy="24" r="6"/><line x1="9" y1="39" x2="39" y2="9"/></svg>
        </div>
        <h3>Private by design</h3>
        <p>Your crates travel sealed, so drivers never see inside them. What you store is your business, full stop.</p>
      </article>

      <article class="security__card reveal" data-delay="4">
        <div class="security__card-icon">
          <svg viewBox="0 0 48 48" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M24 6 L39 12 V23 C39 33 32 39 24 42 C16 39 9 33 9 23 V12 Z"/><polyline points="18 24 22 28 30 18"/></svg>
        </div>
        <h3>Insured, every crate</h3>
        <p>Every crate is covered while it's in our care — on the van, on the shelf, and everywhere in between.</p>
      </article>
    </div>
  </div>
</section>

<!-- ===================================================================
     APP SHOWCASE: "your attic, in your pocket." Three screens with
     one-line callouts. The hero teases the app; this section proves it.
     =================================================================== -->
<section id="app" class="stripe showcase">
  <div class="wrap">
    <div class="showcase__head reveal">
      <p class="eyebrow">The Attic app</p>
      <h2 class="h2">Your attic,<br/><em>in your pocket.</em></h2>
      <p class="lede" style="margin-top:20px;">Every crate gets a name, a photo, and a live journey you can watch. Your stuff is out of the house, never out of reach.</p>
    </div>

    <div class="showcase__grid">
      <figure class="showcase__item reveal" data-delay="1">
        <div class="phone-frame">
          <img src="/images/app/app-crate.png" alt="Crate detail screen: a Camping Gear crate with cover photo, category, and a live journey tracker between home and storage" width="720" height="1600" loading="lazy" decoding="async" />
        </div>
        <figcaption>
          <h3>Every crate, at a glance</h3>
          <p>A photo, a name, and a journey tracker that shows exactly where it is — home, on the road, or stored.</p>
        </figcaption>
      </figure>

      <figure class="showcase__item reveal" data-delay="2">
        <div class="phone-frame">
          <img src="/images/app/app-order.png" alt="Order crates screen: choose a crate count, pick a date on the calendar, and select a morning or afternoon pickup window" width="720" height="1600" loading="lazy" decoding="async" />
        </div>
        <figcaption>
          <h3>Pickup in a few taps</h3>
          <p>Choose how many crates and when. We handle every step after that.</p>
        </figcaption>
      </figure>

      <figure class="showcase__item reveal" data-delay="3">
        <div class="phone-frame">
          <img src="/images/app/app-referrals.png" alt="Refer a friend screen: give $20, get $20 when a friend stores their first crate" width="720" height="1600" loading="lazy" decoding="async" />
        </div>
        <figcaption>
          <h3>Give $20, get $20</h3>
          <p>Share Attic with a friend. When they store a crate, you each earn credit.</p>
        </figcaption>
      </figure>
    </div>

    <div class="showcase__stores reveal" data-delay="2">
      <div class="store-badges">
        <a href="#waitlist" aria-label="App Store — coming soon. Join the waitlist for first access.">
          <img src="/images/appstore-badge.svg" alt="Download on the App Store" width="144" height="48" loading="lazy" decoding="async" />
        </a>
        <a href="#waitlist" aria-label="Google Play — coming soon. Join the waitlist for first access.">
          <img src="/images/googleplay-badge.png" alt="Get it on Google Play" width="124" height="48" loading="lazy" decoding="async" />
        </a>
      </div>
      <p class="store-note">Launching with Denver · Join the waitlist for first access</p>
    </div>
  </div>
</section>

<!-- ===================================================================
     PRICING: transparent details. One big number + slim inclusion list.
     =================================================================== -->
<section id="pricing" class="stripe stripe--paper pricing">
  <div class="wrap">
    <div class="reveal" style="text-align:center;max-width:640px;margin:0 auto 56px;">
      <p class="eyebrow">What it costs</p>
      <h2 class="h2">One price. <em>No surprises.</em></h2>
      <p class="lede" style="margin-top:20px;">Flat rate per crate. Bundled service. Cancel any crate any time. We pick it up for free.</p>
    </div>

    <div class="pricing__card reveal" data-delay="1">
      <div class="pricing__head">
        <div>
          <p class="pricing__label">Flat rate · Colorado</p>
          <h3 class="pricing__title">Per crate, per month.<br/>That's the whole price.</h3>
        </div>
        <div class="pricing__num">
          <span class="pricing__num-dollar">$</span>
          <span>15</span>
          <span class="pricing__num-per">/ crate / mo</span>
        </div>
      </div>

      <div class="pricing__grid">
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Empty crate delivery</h4>
            <p>Free, on every order.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Free retrieval after 4 months</h4>
            <p>Earlier than that, $15/crate flat.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Every crate insured</h4>
            <p>Sealed, scanned, and tracked at every handoff.</p>
          </div>
        </div>
        <div class="pricing__item">
          <div class="pricing__item-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h4>Cancel any crate, any time</h4>
            <p>Send empty crates back. No fee, no contract.</p>
          </div>
        </div>
      </div>

      <div class="pricing__foot">
        <p>No contract. No minimum crate count. No per-mile fees.</p>
        <a class="btn btn-dark" href="#waitlist">Request an invite →</a>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     VALUE: "What Attic does for you." Lifestyle benefits, negative-space
     framing. The payoff, not the comparison; people draw the comparison
     themselves. (The old 3-beat loop was dropped 2026-07-09 — the #how
     section now tells that story properly.)
     =================================================================== -->
<section id="life" class="stripe value">
  <div class="wrap">
    <div class="value__head reveal">
      <p class="eyebrow">What Attic does for you</p>
      <h2 class="h2">Less to deal with.<br/><em>More room to live.</em></h2>
      <p class="lede" style="margin-top:20px;">Attic isn't one more thing to manage. It's the clutter, the hauling, and the worry, gone. Here's what you actually get back.</p>
    </div>

    <div class="value__grid">
      <article class="value__card reveal" data-delay="1" data-tone="t">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 16 V9 H16"/><path d="M39 16 V9 H32"/><path d="M9 32 V39 H16"/><path d="M39 32 V39 H32"/></svg></div>
        <h3>Your space, back</h3>
        <p>The spare room becomes the office. The closet shuts. The garage fits the car again.</p>
      </article>

      <article class="value__card reveal" data-delay="2" data-tone="m">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="24" cy="24" r="8"/><path d="M24 5 V10"/><path d="M24 38 V43"/><path d="M5 24 H10"/><path d="M38 24 H43"/><path d="M10.5 10.5 L14 14"/><path d="M34 34 L37.5 37.5"/><path d="M37.5 10.5 L34 14"/><path d="M10.5 37.5 L14 34"/></svg></div>
        <h3>Your weekends, back</h3>
        <p>No Costco tote runs, no rented vans, no Saturday lost to hauling.</p>
      </article>

      <article class="value__card reveal" data-delay="3" data-tone="sky">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="17" y="7" width="14" height="34" rx="3"/><line x1="21" y1="37" x2="27" y2="37"/></svg></div>
        <h3>Out of sight, one tap away</h3>
        <p>Stored safe across town, not stacked in your hall. Back on your porch tomorrow.</p>
      </article>

      <article class="value__card reveal" data-delay="1" data-tone="moss">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M24 6 L39 12 V23 C39 33 32 39 24 42 C16 39 9 33 9 23 V12 Z"/><polyline points="18 24 22 28 30 18"/></svg></div>
        <h3>Nothing to worry about</h3>
        <p>Insured, sealed, scanned at every handoff, and stored safe in our Denver facility. We've got it from here.</p>
      </article>

      <article class="value__card reveal" data-delay="2" data-tone="t">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="12" y="27" width="22" height="12" rx="1.5"/><rect x="16" y="15" width="14" height="11" rx="1.5"/><line x1="38" y1="10" x2="38" y2="18"/><line x1="34" y1="14" x2="42" y2="14"/></svg></div>
        <h3>Only what you use</h3>
        <p>Pay by the crate. Send some back, add a few more. No contract, ever.</p>
      </article>

      <article class="value__card reveal" data-delay="3" data-tone="moss">
        <div class="value__card-icon"><svg viewBox="0 0 48 48" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 34 C14 20 25 12 37 12 C37 25 26 35 14 34 Z"/><path d="M16 32 L31 17"/></svg></div>
        <h3>A lighter home</h3>
        <p>Less to trip over, less to manage, less on your mind.</p>
      </article>
    </div>

    <div class="value__gone reveal" data-delay="2">
      <p class="value__gone-label">And here's what goes with it</p>
      <ul class="value__gone-list">
        <li>The weekend haul</li>
        <li>The Costco tote run</li>
        <li>Digging through the closet</li>
        <li>Square footage you can't use</li>
        <li>The low-grade mental clutter</li>
      </ul>
      <p class="value__gone-closer">Gone. <em>That's the whole idea.</em></p>
    </div>
  </div>
</section>

<!-- ===================================================================
     FAQ: four essential questions before the final CTA.
     =================================================================== -->
<section id="faq" class="stripe stripe--paper faq">
  <div class="wrap" style="display:grid;grid-template-columns:1fr 1.3fr;gap:60px;align-items:start;">
    <div class="reveal">
      <p class="eyebrow">FAQ</p>
      <h2 class="h2">The things<br/><em>people ask first.</em></h2>
    </div>
    <div class="reveal faq__list" data-delay="1">
      <details>
        <summary>How does the pickup work?</summary>
        <p>You schedule a window in the app. A driver comes to your door, seals and scans each crate, and loads them onto the truck. You don't haul anything. No trips to a self-storage lot, no rented vans.</p>
      </details>
      <details>
        <summary>What if I need something back fast?</summary>
        <p>Tap "send it back" in the app. We bring the crate to your door the next available window, usually next day. Free after a crate has been stored for four months; $15 per crate flat before that.</p>
      </details>
      <details>
        <summary>How do you keep my things safe?</summary>
        <p>Every crate is closed at your door with a one-time, QR-coded security seal that can't be opened and resealed. It's scanned at pickup, on the way into the facility, when it's shelved, and on every return — a full chain of custody. And every crate is insured.</p>
      </details>
      <details>
        <summary>Do I have to commit?</summary>
        <p>No. There's no contract, no minimum crate count, and no monthly subscription you can't escape. When a crate is empty at your place, tap "send it back." We pick it up for free, and that crate's monthly fee stops at the next billing cycle.</p>
      </details>
    </div>
  </div>
</section>

<!-- ===================================================================
     FINAL CTA / WAITLIST. Last conversion shot. The Denver geography
     pitch is folded into the sub-copy rather than a separate section.
     =================================================================== -->
<section id="waitlist" class="cta-final">
  <div class="wrap-narrow">
    <h2 class="reveal">Ready to get some <em>space back?</em></h2>
    <p class="sub reveal" data-delay="1">
      Attic is opening Denver in small batches, from Highland to Cherry Creek and growing.
      Drop your email and zip. We'll send your invite when we reach your neighborhood.
    </p>
    <ul class="trust-chips reveal" data-delay="1" aria-label="What's included">
      <li>Picked up &amp; delivered</li>
      <li>Every crate insured</li>
      <li>No contract</li>
      <li>Cancel anytime</li>
    </ul>
    <form class="email-form reveal" data-delay="2" data-email-form novalidate>
      <div data-email-fields>
        <div class="email-form__row">
          <input
            type="email"
            name="email"
            placeholder="you@email.com"
            required
            autocomplete="email"
            inputmode="email"
            aria-label="Email address"
            class="email-form__input"
          />
          <span class="email-form__divider" aria-hidden="true"></span>
          <input
            type="text"
            name="zip"
            placeholder="80210"
            required
            autocomplete="postal-code"
            inputmode="numeric"
            pattern="\d{5}"
            maxlength="5"
            aria-label="ZIP code"
            class="email-form__input email-form__zip"
          />
        </div>
        <button type="submit" class="email-form__submit">Request invite</button>
      </div>
      <input type="text" name="_h" tabindex="-1" autocomplete="off" aria-hidden="true" class="email-form__honeypot" />
      <div class="email-form__error" data-email-error role="alert"></div>
      <div class="email-form__success" data-email-success role="status">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>You're on the list. Check your inbox to confirm. We sent a quick note to make sure it's really you.</span>
      </div>
      <p class="email-form__fine">We'll email you when your invite's ready, and occasionally with launch updates. Unsubscribe anytime.</p>
    </form>

    <!-- Coming-soon app teaser using the official App Store / Google Play
         badges. The apps aren't public yet, so the waitlist stays the single
         live action. When the apps ship, point each badge at its listing. -->
    <div class="app-soon reveal" data-delay="2">
      <p class="app-soon__label">Native apps launching with Denver</p>
      <div class="app-soon__badges">
        <img class="app-badge-img" src="/images/appstore-badge.svg" alt="Download on the App Store — coming soon" width="144" height="48" loading="lazy" decoding="async" />
        <img class="app-badge-img" src="/images/googleplay-badge.png" alt="Get it on Google Play — coming soon" width="124" height="48" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

</main>

<!-- ===================================================================
     STICKY MOBILE CTA — phones only. Slides up once the hero scrolls out
     and hides again when the waitlist form enters view, so it never
     duplicates the visible form. Restores a persistent action on mobile,
     where the nav menu is collapsed. Toggled by motion.js.
     =================================================================== -->
<div class="mobile-cta" data-mobile-cta aria-hidden="true">
  <a class="btn btn-primary" href="#waitlist">Request an invite</a>
</div>

</BaseLayout>
