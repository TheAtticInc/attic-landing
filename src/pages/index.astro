---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';
---

<BaseLayout
  title="Attic — Personal storage, on demand in Denver"
  description="Attic picks up your bins, stores them safely in our Denver facility, and delivers them back when you need them. $12 per bin per month, flat."
  ogTitle="Attic — Personal storage, on demand"
  ogDescription="Your things, out of the way and on demand. $12/bin/month."
>


<!-- ===================================================================
     HERO
     =================================================================== -->
<header class="hero">
  <div class="hero-dust" data-dust aria-hidden="true"></div>
  <div class="wrap">
    <div class="hero__grid">
      <!-- LEFT: copy -->
      <div>
        <span class="hero__label">
          <span class="hero__label-dot"></span>
          Now in Denver &amp; the Front Range
        </span>
        <h1 class="hero__h1">Your things,<br/><em>tucked away.</em></h1>
        <p class="hero__lede">Storage that comes to you — not the other way around.</p>
        <p class="hero__sub">
          We drop off sturdy bins, pick them up when you're packed,
          and store them in our climate-controlled Denver facility.
          Call anything back in a tap. $12 a bin, a month.
        </p>
        <div class="hero__cta">
          <a class="btn btn-primary btn-lg" href="#waitlist">Request an invite</a>
          <a class="btn btn-ghost btn-lg" href="#how">See how it works →</a>
        </div>
        <div class="hero__ticker" data-ticker aria-live="polite">
          <span class="hero__ticker-dot"></span>
          <div class="hero__ticker-lines">
            <span data-ticker-line><strong>1,284</strong> bins tucked in right now</span>
            <span data-ticker-line>Average return time: <strong>next day by 6pm</strong></span>
            <span data-ticker-line><strong>99.7%</strong> on-time delivery in Denver this month</span>
            <span data-ticker-line>Scanned <strong>6,420 times</strong> in the last 30 days</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: phone stack over attic illustration -->
      <div class="hero__stage" aria-hidden="true">
        <div class="hero__attic">
          <!-- Attic cross-section — a cozy wooden house with a glowing interior -->
          <svg viewBox="0 0 560 560" preserveAspectRatio="xMidYMid meet">
            <defs>
              <linearGradient id="roof" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#C65D3C"/>
                <stop offset="100%" stop-color="#8A3B1F"/>
              </linearGradient>
              <linearGradient id="wall" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ECDEC7"/>
                <stop offset="100%" stop-color="#D4C3A4"/>
              </linearGradient>
              <radialGradient id="glow" cx="50%" cy="40%">
                <stop offset="0%" stop-color="#FBEECB" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#FBEECB" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <!-- soft glow behind house -->
            <circle cx="280" cy="240" r="260" fill="url(#glow)"/>
            <!-- house silhouette (cross-section) -->
            <g>
              <!-- roof -->
              <path d="M 80 280 L 280 80 L 480 280 Z" fill="url(#roof)"/>
              <!-- roof shingles -->
              <g stroke="#8A3B1F" stroke-width="1.2" opacity="0.35" fill="none">
                <path d="M 120 260 L 280 100 L 440 260"/>
                <path d="M 150 240 L 280 120 L 410 240"/>
                <path d="M 180 220 L 280 140 L 380 220"/>
                <path d="M 210 200 L 280 160 L 350 200"/>
              </g>
              <!-- attic floor -->
              <rect x="80" y="280" width="400" height="6" fill="#23180F" opacity="0.25"/>
              <!-- attic window (circle) -->
              <circle cx="280" cy="200" r="26" fill="#FBEECB" opacity="0.9"/>
              <circle cx="280" cy="200" r="26" fill="none" stroke="#8A3B1F" stroke-width="3"/>
              <line x1="254" y1="200" x2="306" y2="200" stroke="#8A3B1F" stroke-width="2"/>
              <line x1="280" y1="174" x2="280" y2="226" stroke="#8A3B1F" stroke-width="2"/>
              <!-- ground line suggestion -->
            </g>
            <!-- tiny bins stacked on attic floor -->
            <g transform="translate(130 240)">
              <rect x="0" y="0" width="36" height="30" rx="3" fill="#C65D3C" opacity="0.85"/>
              <rect x="6" y="4" width="24" height="4" rx="1" fill="#FFF8EE" opacity="0.5"/>
              <rect x="40" y="6" width="32" height="24" rx="3" fill="#6B8E5A" opacity="0.85"/>
              <rect x="44" y="10" width="24" height="3" rx="1" fill="#FFF8EE" opacity="0.5"/>
              <rect x="6" y="-18" width="30" height="18" rx="3" fill="#E8B84A" opacity="0.85"/>
            </g>
            <g transform="translate(360 248)">
              <rect x="0" y="0" width="40" height="26" rx="3" fill="#5A7FA3" opacity="0.85"/>
              <rect x="5" y="4" width="28" height="3" rx="1" fill="#FFF8EE" opacity="0.5"/>
              <rect x="44" y="-12" width="32" height="38" rx="3" fill="#A6436A" opacity="0.75"/>
            </g>
          </svg>
        </div>

        <!-- phone mock stack — cycles through 3 screens -->
        <div class="hero__phone-stack" data-phone-stack>

          <!-- CARD 1: Home -->
          <div class="phone-card" data-phone-card>
            <div class="phone">
              <div class="phone__notch"></div>
              <div class="phone__status">
                <span>9:41</span>
                <span>●●● ▲ 🔋</span>
              </div>
              <div class="phone__screen" style="background: #F5EADB;">
                <div style="padding: 14px 2px 8px;">
                  <div style="font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-0.02em;color:#23180F;line-height:1.1;">Good morning,<br/>Luke.</div>
                  <div style="font-size:12.5px;color:#8C7A68;margin-top:6px;">8 bins tucked in · 2 with you</div>
                </div>
                <div style="background:#FFFAF1;border-radius:14px;padding:14px;margin-bottom:10px;box-shadow:0 1px 2px rgba(80,52,28,0.06);">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                    <div>
                      <div style="font-family:'Fraunces',serif;font-weight:600;font-size:14.5px;color:#23180F;">Bin #042</div>
                      <div style="font-size:11.5px;color:#8C7A68;">Holiday decor</div>
                    </div>
                    <span style="background:#DDE6D0;color:#4E6B41;padding:3px 8px;border-radius:99px;font-size:10px;font-weight:600;">IN THE ATTIC</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;font-size:11px;color:#8C7A68;">
                    <span style="width:6px;height:6px;border-radius:99px;background:#6B8E5A;"></span>
                    Shelf B-12 · tucked in 24 days
                  </div>
                </div>
                <div style="background:#FFFAF1;border-radius:14px;padding:14px;margin-bottom:10px;box-shadow:0 1px 2px rgba(80,52,28,0.06);">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                    <div>
                      <div style="font-family:'Fraunces',serif;font-weight:600;font-size:14.5px;color:#23180F;">Bin #017</div>
                      <div style="font-size:11.5px;color:#8C7A68;">Winter coats</div>
                    </div>
                    <span style="background:#FBEECB;color:#B8861F;padding:3px 8px;border-radius:99px;font-size:10px;font-weight:600;">ON THE MOVE</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;font-size:11px;color:#8C7A68;">
                    <span style="width:6px;height:6px;border-radius:99px;background:#E8B84A;"></span>
                    Out for delivery · ETA 4:20 PM
                  </div>
                </div>
                <button style="width:100%;background:#C65D3C;color:#FFF8EE;border:none;border-radius:99px;padding:14px;font-family:'Inter',sans-serif;font-weight:600;font-size:14px;margin-top:4px;">+ Order more bins</button>
              </div>
            </div>
          </div>

          <!-- CARD 2: Tracking -->
          <div class="phone-card" data-phone-card>
            <div class="phone">
              <div class="phone__notch"></div>
              <div class="phone__status">
                <span>9:41</span>
                <span>●●● ▲ 🔋</span>
              </div>
              <div class="phone__screen" style="background:#F5EADB;padding:0 0 20px;">
                <!-- map -->
                <div style="height:260px;background:linear-gradient(160deg,#DDE6D0 0%,#CADBBE 100%);position:relative;overflow:hidden;">
                  <!-- streets -->
                  <svg viewBox="0 0 300 260" width="100%" height="100%" style="position:absolute;inset:0;">
                    <g stroke="#FFFAF1" stroke-width="3" fill="none" opacity="0.9">
                      <path d="M -10 60 L 320 90"/>
                      <path d="M -10 150 L 320 130"/>
                      <path d="M -10 210 L 320 190"/>
                      <path d="M 60 -10 L 90 280"/>
                      <path d="M 180 -10 L 210 280"/>
                    </g>
                    <!-- route -->
                    <path d="M 40 220 Q 100 200 120 150 T 200 90 L 230 80" stroke="#C65D3C" stroke-width="3" fill="none" stroke-dasharray="6 5" stroke-linecap="round"/>
                    <!-- driver pin -->
                    <circle cx="120" cy="150" r="10" fill="#C65D3C"/>
                    <circle cx="120" cy="150" r="18" fill="#C65D3C" opacity="0.25"/>
                    <circle cx="120" cy="150" r="6" fill="#FFF8EE"/>
                    <!-- dest pin -->
                    <g transform="translate(230 80)">
                      <path d="M 0 -20 C -8 -20 -14 -14 -14 -6 C -14 4 0 14 0 14 C 0 14 14 4 14 -6 C 14 -14 8 -20 0 -20 Z" fill="#23180F"/>
                      <circle cx="0" cy="-6" r="4" fill="#F5EADB"/>
                    </g>
                  </svg>
                </div>
                <div style="padding:18px 18px 0;">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                    <div style="font-family:'Fraunces',serif;font-weight:600;font-size:20px;letter-spacing:-0.02em;color:#23180F;">Your bin's on the move</div>
                  </div>
                  <div style="display:flex;gap:10px;margin-bottom:14px;">
                    <div style="flex:1;background:#FFFAF1;border-radius:10px;padding:10px 12px;">
                      <div style="font-size:10px;color:#8C7A68;text-transform:uppercase;letter-spacing:0.8px;font-family:'JetBrains Mono',monospace;">Driver</div>
                      <div style="font-family:'Fraunces',serif;font-weight:600;font-size:15px;color:#23180F;margin-top:2px;">Marcus</div>
                    </div>
                    <div style="flex:1;background:#FFFAF1;border-radius:10px;padding:10px 12px;">
                      <div style="font-size:10px;color:#8C7A68;text-transform:uppercase;letter-spacing:0.8px;font-family:'JetBrains Mono',monospace;">ETA</div>
                      <div style="font-family:'Fraunces',serif;font-weight:600;font-size:15px;color:#C65D3C;margin-top:2px;">12 min</div>
                    </div>
                  </div>
                  <div style="background:#FFFAF1;border-radius:10px;padding:12px;font-size:12px;color:#5A4A3C;">
                    <span style="color:#6B8E5A;font-weight:600;">●</span> Picked up at warehouse — 9:14 AM
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- CARD 3: Bin detail -->
          <div class="phone-card" data-phone-card>
            <div class="phone">
              <div class="phone__notch"></div>
              <div class="phone__status">
                <span>9:41</span>
                <span>●●● ▲ 🔋</span>
              </div>
              <div class="phone__screen" style="background:#F5EADB;">
                <div style="padding:14px 2px 14px;">
                  <div style="font-size:11.5px;color:#8C7A68;font-family:'JetBrains Mono',monospace;letter-spacing:0.8px;text-transform:uppercase;margin-bottom:4px;">Bin · #042</div>
                  <div style="font-family:'Fraunces',serif;font-weight:600;font-size:26px;letter-spacing:-0.02em;color:#23180F;line-height:1.1;">Holiday decor</div>
                </div>
                <!-- hero photo of bin contents placeholder -->
                <div style="height:150px;border-radius:14px;background:linear-gradient(160deg,#C65D3C 0%,#8A3B1F 100%);display:flex;align-items:center;justify-content:center;margin-bottom:14px;position:relative;overflow:hidden;">
                  <svg width="70" height="70" viewBox="0 0 60 60" style="opacity:0.9;">
                    <rect x="10" y="18" width="40" height="32" rx="2" fill="#FFFAF1"/>
                    <rect x="14" y="22" width="32" height="4" rx="1" fill="#C65D3C" opacity="0.4"/>
                    <rect x="8" y="14" width="44" height="8" rx="1" fill="#FFFAF1"/>
                    <circle cx="30" cy="34" r="3" fill="#23180F" opacity="0.2"/>
                  </svg>
                </div>
                <div style="background:#FFFAF1;border-radius:14px;padding:14px 16px;margin-bottom:10px;">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.8px;text-transform:uppercase;color:#8C7A68;">Location</div>
                    <span style="background:#DDE6D0;color:#4E6B41;padding:3px 8px;border-radius:99px;font-size:10px;font-weight:600;">TUCKED IN</span>
                  </div>
                  <div style="font-family:'Fraunces',serif;font-weight:600;font-size:18px;color:#23180F;">Shelf B-12 · Row 3</div>
                  <div style="font-size:12px;color:#8C7A68;margin-top:2px;">Last scanned 24 days ago</div>
                </div>
                <button style="width:100%;background:#C65D3C;color:#FFF8EE;border:none;border-radius:99px;padding:14px;font-family:'Inter',sans-serif;font-weight:600;font-size:14px;">Call this bin back →</button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</header>

<!-- ===================================================================
     PROOF STRIP
     =================================================================== -->
<section class="proof">
  <div class="wrap">
    <div class="proof__grid">
      <div class="proof__item">
        <div class="proof__num"><span data-count="1284" data-suffix="">0</span></div>
        <div class="proof__label">Bins in the attic</div>
      </div>
      <div class="proof__item">
        <div class="proof__num"><span data-count="99.7" data-decimals="1" data-suffix="%">0</span></div>
        <div class="proof__label">On-time deliveries</div>
      </div>
      <div class="proof__item">
        <div class="proof__num"><span data-count="24" data-suffix="h">0</span></div>
        <div class="proof__label">Avg. return window</div>
      </div>
      <div class="proof__item">
        <div class="proof__num"><span data-count="2000" data-prefix="$">0</span></div>
        <div class="proof__label">Insured per bin</div>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     DAY WITH ATTIC
     =================================================================== -->
<section id="how" class="stripe stripe--paper day">
  <div class="wrap">
    <div class="day__head reveal">
      <div class="day__head-left">
        <p class="eyebrow">A day with Attic</p>
        <h2 class="h2">Six taps. One truck.<br/><em>Zero storage-unit weekends.</em></h2>
      </div>
      <p class="body-lg" style="max-width:360px;">From "I need bins" to "it's in my kitchen again" — the whole loop, on a single timeline.</p>
    </div>

    <div class="day__track">
      <div class="day__rail" aria-hidden="true"></div>

      <div class="day__step reveal" data-delay="1">
        <div class="day__pin" data-tone="t">1</div>
        <p class="day__time">Tuesday · 9:12 AM</p>
        <h3>You order bins</h3>
        <p>Tap how many you want. First drop-off's free.</p>
      </div>
      <div class="day__step reveal" data-delay="2">
        <div class="day__pin" data-tone="t">2</div>
        <p class="day__time">Wednesday · 11:30 AM</p>
        <h3>We drop them off</h3>
        <p>Empty, sealed, stackable. Ready to fill at your pace.</p>
      </div>
      <div class="day__step reveal" data-delay="3">
        <div class="day__pin" data-tone="m">3</div>
        <p class="day__time">Saturday · Afternoon</p>
        <h3>You pack them</h3>
        <p>Label from the app. Snap photos of what's inside.</p>
      </div>
      <div class="day__step reveal" data-delay="4">
        <div class="day__pin" data-tone="m">4</div>
        <p class="day__time">Monday · 2:40 PM</p>
        <h3>We pick them up</h3>
        <p>A driver loads them. You get a "tucked in" receipt.</p>
      </div>
      <div class="day__step reveal" data-delay="5">
        <div class="day__pin" data-tone="moss">5</div>
        <p class="day__time">Stored indefinitely</p>
        <h3>They rest in the attic</h3>
        <p>Climate-controlled. Chain-of-custody scanned.</p>
      </div>
      <div class="day__step reveal" data-delay="5">
        <div class="day__pin" data-tone="moss">6</div>
        <p class="day__time">December · Next day</p>
        <h3>Call anything back</h3>
        <p>Tap "send it back." It's on your porch tomorrow.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================================================================
     FACILITY
     =================================================================== -->
<section class="stripe stripe--dark facility">
  <div class="wrap">
    <div class="facility__grid">
      <div class="reveal">
        <p class="eyebrow">Inside the attic</p>
        <h2 class="h2" style="color:#F5EADB;">A proper home for<br/>your things.</h2>
        <p class="body-lg" style="margin-top:24px;max-width:460px;">Our Denver facility isn't a garage unit. It's a climate-controlled, scan-tracked, insured home — purpose-built for the stuff you want to keep but don't need underfoot.</p>

        <div class="facility__features">
          <div class="fac-feat reveal" data-delay="1">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div>
              <h4>Secured 24/7</h4>
              <p>Keycard access, 16 cameras, motion sensors. Only named staff ever touch a bin.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="2">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
            </div>
            <div>
              <h4>Climate-controlled</h4>
              <p>Held at 65–72°F year-round. No freeze, no bake, no musty-garage funk.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="3">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3h-3zM18 14h3M14 18h3M18 21h3"/></svg>
            </div>
            <div>
              <h4>Every bin scanned</h4>
              <p>QR-coded and scanned at pickup, intake, shelf placement, and return. Full custody trail.</p>
            </div>
          </div>
          <div class="fac-feat reveal" data-delay="4">
            <div class="fac-feat__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h4>Insured to $2,000</h4>
              <p>Every bin, every month, baked into the price. No extra rider to buy.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="facility__scene reveal" data-delay="2" aria-hidden="true">
        <!-- Warehouse interior cross-section: shelving with bins + glow -->
        <svg viewBox="0 0 600 450" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="shelfGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3A2A1A"/>
              <stop offset="100%" stop-color="#1A120A"/>
            </linearGradient>
            <radialGradient id="warmLight" cx="50%" cy="30%">
              <stop offset="0%" stop-color="#FBEECB" stop-opacity="0.4"/>
              <stop offset="60%" stop-color="#E8B84A" stop-opacity="0.1"/>
              <stop offset="100%" stop-color="#140D07" stop-opacity="0"/>
            </radialGradient>
          </defs>

          <!-- background glow -->
          <rect width="600" height="450" fill="#140D07"/>
          <ellipse cx="300" cy="130" rx="300" ry="200" fill="url(#warmLight)"/>

          <!-- floor -->
          <path d="M 0 380 L 600 380 L 600 450 L 0 450 Z" fill="#0A0704"/>
          <!-- perspective floor lines -->
          <g stroke="#3A2A1A" stroke-width="1" opacity="0.5">
            <line x1="0" y1="400" x2="600" y2="400"/>
            <line x1="0" y1="420" x2="600" y2="420"/>
          </g>

          <!-- warehouse shelving (3 rows, deep perspective) -->
          <!-- back row, smallest -->
          <g transform="translate(140 100)">
            <rect x="0" y="0" width="320" height="240" fill="url(#shelfGrad)" stroke="#4A3820" stroke-width="1"/>
            <!-- horizontal shelf lines -->
            <line x1="0" y1="60" x2="320" y2="60" stroke="#5A4028" stroke-width="2"/>
            <line x1="0" y1="120" x2="320" y2="120" stroke="#5A4028" stroke-width="2"/>
            <line x1="0" y1="180" x2="320" y2="180" stroke="#5A4028" stroke-width="2"/>
            <!-- vertical supports -->
            <line x1="80" y1="0" x2="80" y2="240" stroke="#4A3820" stroke-width="1.5"/>
            <line x1="160" y1="0" x2="160" y2="240" stroke="#4A3820" stroke-width="1.5"/>
            <line x1="240" y1="0" x2="240" y2="240" stroke="#4A3820" stroke-width="1.5"/>

            <!-- bins: row 1 -->
            <g transform="translate(8 14)">
              <rect width="60" height="42" rx="3" fill="#C65D3C"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>
            <g transform="translate(88 14)">
              <rect width="60" height="42" rx="3" fill="#6B8E5A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>
            <g transform="translate(168 14)">
              <rect width="60" height="42" rx="3" fill="#E8B84A"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#23180F" opacity="0.3"/>
            </g>
            <g transform="translate(248 14)">
              <rect width="60" height="42" rx="3" fill="#5A7FA3"/><rect x="6" y="6" width="48" height="3" rx="1" fill="#FFF8EE" opacity="0.4"/>
            </g>

            <!-- row 2 -->
